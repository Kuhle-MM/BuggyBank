<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/fragment_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".CreateTransactionFragment">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/main"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_constraintEnd_toEndOf="@+id/btnAddImage"
        app:layout_constraintStart_toEndOf="@+id/btnAddImage">


        <TextView
            android:id="@+id/textView"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="19dp"
            android:text="Create A Transaction"
            app:layout_constraintBottom_toTopOf="@+id/textView2"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent" />


        <TextView
            android:id="@+id/textView2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="17dp"
            android:layout_marginBottom="21dp"
            android:text="ADD NEW TRANSACTION"
            app:layout_constraintBottom_toTopOf="@+id/textView3"
            app:layout_constraintStart_toStartOf="parent" />

        <TextView
            android:id="@+id/textView3"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="15dp"
            android:layout_marginTop="128dp"
            android:text="Title:"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />


        <EditText
            android:id="@+id/etTitle"
            android:layout_width="0dp"
            android:layout_height="38dp"
            android:layout_marginStart="16dp"
            android:layout_marginTop="31dp"
            android:layout_marginEnd="16dp"
            android:layout_marginBottom="33dp"
            android:hint="Title"
            android:inputType="text"
            app:layout_constraintBottom_toBottomOf="@+id/textView5"
            app:layout_constraintEnd_toStartOf="@+id/textView"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="@+id/textView3" />

        <TextView
            android:id="@+id/textView4"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="1dp"
            android:layout_marginTop="21dp"
            android:text="Type:"
            app:layout_constraintStart_toStartOf="@+id/spType"
            app:layout_constraintTop_toBottomOf="@+id/textView2" />

        <Spinner
            android:id="@+id/spType"
            android:layout_width="108dp"
            android:layout_height="48dp"
            android:layout_marginStart="128dp"
            android:layout_marginTop="31dp"
            android:layout_marginBottom="31dp"
            app:layout_constraintBottom_toTopOf="@+id/spCategory"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="@+id/textView4" />

        <TextView
            android:id="@+id/textView5"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="1dp"
            android:layout_marginTop="64dp"
            android:text="AMOUNT:"
            app:layout_constraintStart_toStartOf="@+id/etAmount"
            app:layout_constraintTop_toBottomOf="@+id/textView3" />


        <EditText
            android:id="@+id/etAmount"
            android:layout_width="0dp"
            android:layout_height="43dp"
            android:layout_marginTop="27dp"
            android:layout_marginBottom="29dp"
            android:hint="Amount"
            android:inputType="numberDecimal"
            app:layout_constraintBottom_toTopOf="@+id/spPayment"
            app:layout_constraintEnd_toEndOf="@+id/etTitle"
            app:layout_constraintStart_toStartOf="@+id/textView8"
            app:layout_constraintTop_toTopOf="@+id/textView5" />

        <TextView
            android:id="@+id/textView6"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="1dp"
            android:layout_marginTop="14dp"
            android:text="CATEGORY:"
            app:layout_constraintStart_toStartOf="@+id/spType"
            app:layout_constraintTop_toBottomOf="@+id/etTitle" />

        <Spinner
            android:id="@+id/spCategory"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_marginTop="27dp"
            android:layout_marginBottom="19dp"
            app:layout_constraintBottom_toBottomOf="@+id/textView7"
            app:layout_constraintEnd_toEndOf="@+id/spType"
            app:layout_constraintStart_toStartOf="@+id/spType"
            app:layout_constraintTop_toTopOf="@+id/textView6" />

        <TextView
            android:id="@+id/textView7"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="1dp"
            android:layout_marginTop="56dp"
            android:text="PAYMENT METHOD:"
            app:layout_constraintStart_toStartOf="@+id/etAmount"
            app:layout_constraintTop_toBottomOf="@+id/textView5" />

        <Spinner
            android:id="@+id/spPayment"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_marginStart="15dp"
            android:layout_marginTop="103dp"
            android:layout_marginEnd="12dp"
            android:layout_marginBottom="103dp"
            app:layout_constraintBottom_toBottomOf="@+id/textView9"
            app:layout_constraintEnd_toEndOf="@+id/spCategory"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/spType" />

        <TextView
            android:id="@+id/textView8"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="1dp"
            android:layout_marginTop="11dp"
            android:text="DATE:"
            app:layout_constraintStart_toStartOf="@+id/etDate"
            app:layout_constraintTop_toBottomOf="@+id/spPayment" />

        <EditText
            android:id="@+id/etDate"
            android:layout_width="313dp"
            android:layout_height="46dp"
            android:layout_marginTop="30dp"
            android:layout_marginBottom="31dp"
            android:focusable="false"
            android:hint="Select date"
            android:inputType="none"
            app:layout_constraintBottom_toTopOf="@+id/etStartTime"
            app:layout_constraintEnd_toStartOf="@+id/etEndTime"
            app:layout_constraintStart_toStartOf="@+id/etEndTime"
            app:layout_constraintTop_toBottomOf="@+id/spPayment" />

        <TextView
            android:id="@+id/textView9"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="15dp"
            android:layout_marginTop="204dp"
            android:layout_marginBottom="203dp"
            android:text="START TIME"
            app:layout_constraintBottom_toBottomOf="@+id/btnAddImage"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="@+id/spCategory" />

        <EditText
            android:id="@+id/etStartTime"
            android:layout_width="122dp"
            android:layout_height="40dp"
            android:layout_marginTop="96dp"
            android:layout_marginBottom="97dp"
            android:focusable="false"
            android:hint="HH:MM"
            android:inputType="none"
            app:layout_constraintBottom_toTopOf="@+id/btnAddImage"
            app:layout_constraintStart_toStartOf="@+id/textView9"
            app:layout_constraintTop_toTopOf="@+id/textView8" />

        <TextView
            android:id="@+id/textView10"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="END TIME"
            app:layout_constraintStart_toStartOf="@+id/etEndTime"
            app:layout_constraintTop_toBottomOf="@+id/etDate" />

        <EditText
            android:id="@+id/etEndTime"
            android:layout_width="133dp"
            android:layout_height="0dp"
            android:layout_marginStart="37dp"
            android:focusable="false"
            android:hint="HH:MM"
            android:inputType="none"
            app:layout_constraintBottom_toBottomOf="@+id/etStartTime"
            app:layout_constraintStart_toEndOf="@+id/etStartTime"
            app:layout_constraintTop_toBottomOf="@+id/textView10" />

        <TextView
            android:id="@+id/textView11"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginTop="8dp"
            android:text="DESCRIPTION:"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/etStartTime" />

        <EditText
            android:id="@+id/editTextDescription"
            android:layout_width="319dp"
            android:layout_height="wrap_content"
            android:layout_marginBottom="146dp"
            android:hint="Description"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@+id/etEndTime"
            app:layout_constraintStart_toStartOf="@+id/etEndTime" />

        <FrameLayout
            android:id="@+id/btnAddImage"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_marginStart="15dp"
            android:layout_marginTop="17dp"
            android:layout_marginEnd="25dp"
            android:layout_marginBottom="17dp"
            android:background="@drawable/bg_dashed_border"
            android:clickable="true"
            android:focusable="true"
            android:padding="12dp"
            app:layout_constraintBottom_toTopOf="@+id/btnAdd"
            app:layout_constraintEnd_toStartOf="@+id/imagePreview"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/editTextDescription">
            <!--https://developer.android.com/reference/android/view/View.html#attr_android:clickable-->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:orientation="horizontal">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:contentDescription="Add image"
                    android:src="@drawable/cameraadd" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:text="Add image" />
            </LinearLayout>
        </FrameLayout>

        <ImageView
            android:id="@+id/imagePreview"
            android:layout_width="103dp"
            android:layout_height="0dp"
            android:layout_gravity="center"
            android:scaleType="centerCrop"
            app:layout_constraintBottom_toTopOf="@+id/btnAdd"
            app:layout_constraintEnd_toEndOf="@+id/editTextDescription"
            app:layout_constraintTop_toTopOf="@+id/btnAddImage" />

        <Button
            android:id="@+id/btnAdd"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="17dp"
            android:layout_marginBottom="2dp"
            android:text="Add"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</FrameLayout>
